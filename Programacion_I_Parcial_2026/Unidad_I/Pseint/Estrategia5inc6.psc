Algoritmo Estrategia5_6
	
	definir num1, num2, producto como real
	
	Escribir "Ingrese el primer numero: "
	leer num1
	
	Escribir "Ingrese el segundo numero: "
	leer num2
	
	si num1 != 50 y num2 != 50 Entonces
		
		producto = num1 * num2
		
		escribir "El producto del primer y segundo numero distintos de 50 es: ", producto
		
	sino
		
		Escribir  "Uno de los numero es 50(o ambos), no se puede realizar"
		
	FinSi
	
	
	
FinAlgoritmo
